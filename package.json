{
  "name": "kvant.desktop",
  "version": "2.1.1",
  "description": "Electron-приложение для работы с API. Поддерживает Windows и macOS.",
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "test": "jest",
    "test:e2e": "playwright test"
  },
  "build": {
    "appId": "ru.kvantorium.desktop",
    "productName": "Кванториум",
    "artifactName": "${name}-setup-${version}.${ext}",
    "icon": "build/icon.ico",
    "files": [
      "main.js",
      "package.json",
      "package-lock.json",
      "renderer/**/*",
      "files/**/*",
      "fonts/**/*",
      "scripts/**/*",
      "build/**/*",
      "!dist",
      "!dist/**/*",
      "!dist-*",
      "!dist-*/**/*",
      "!coverage",
      "!coverage/**/*",
      "!tests",
      "!tests/**/*",
      "!playwright-report",
      "!playwright-report/**/*",
      "!test-results",
      "!test-results/**/*"
    ],
    "win": {
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "electron-updater": "^6.8.3",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "jest": "^29.0.0",
    "jest-environment-jsdom": "^30.3.0",
    "jest-environment-node": "^29.0.0",
    "playwright": "^1.40.0"
  }
}
